{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "VehicleApi": {
    "BaseUrl": "https://vpic.nhtsa.dot.gov/api/vehicles/",
    "Endpoints": {
      "AllMakes": "getallmakes?format=json",
      "VehicleTypes": "GetVehicleTypesForMakeId/{0}?format=json",
      "Models": "GetModelsForMakeIdYear/makeId/{0}/modelyear/{1}?format=json"
    }
  },
  "CacheSettings": {
    "CarMakesDurationMinutes": 1440,
    "VehicleTypesDurationMinutes": 1440,
    "ModelsDurationMinutes": 60
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
