@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5" id="carApp" v-cloak>
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-black rounded-top-4">

            <h3 class="mb-0">
                <i class="fa-solid fa-car me-2"></i>
                Car Explorer
            </h3>

            <small>
                Find your perfect vehicle
            </small>

        </div>
        <div class="card-body p-4">
            <div class="row g-4">
                <!-- Car Make -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="fa-solid fa-industry me-2"></i>
                        Car Make
                    </label>
                    <tom-select v-model="selectedMake"
                                :options="makes"
                                value-field="make_ID"
                                label-field="make_Name"
                                placeholder="Search Make..."
                        @@change="loadVehicleTypes">
                    </tom-select>
                </div>
                <!-- Vehicle Type -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="fa-solid fa-car-side me-2"></i>
                        Vehicle Type
                    </label>
                    <tom-select v-model="selectedType"
                                :options="vehicleTypes"
                                value-field="vehicleTypeName"
                                label-field="vehicleTypeName"
                                placeholder="Select Type">
                    </tom-select>
                </div>
                <!-- Year -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="fa-solid fa-calendar-days me-2"></i>
                        Manufacture Year
                    </label>

                    <tom-select v-model="year"
                                :options="years"
                                placeholder="Select Year">
                    </tom-select>
                </div>
            </div>
            <div class="mt-4" style="text-align: center;">
                <button class="btn btn-outline-dark w-30 py-2"
                    @@click="loadModels"
                        :disabled="loading">
                    <span v-if="!loading">
                        <i class="fa-solid fa-magnifying-glass me-2"></i>Search Vehicles
                    </span>
                    <span v-else>
                        <span class="spinner-border spinner-border-sm">
                        </span>
                        Loading...
                    </span>
                </button>
            </div>
        </div>
    </div>
    <!-- Models Result -->

    <div class="mt-5">

        <h3 class="mb-4">
            <i class="fa-solid fa-list me-2"></i>
            Available Models
        </h3>

        <div v-if="models.length === 0"
             class="alert alert-light text-center">

            No models found

        </div>

        <div v-if="hasSearched && models.length > 0"
             class="table-responsive">

            <table class="table table-hover table-bordered align-middle">

                <thead class="table-primary">

                    <tr>

                        <th>#</th>

                        <th>Model Name</th>

                    </tr>

                </thead>

                <tbody>

                    <tr v-for="(model,index) in models"
                        :key="model.model_ID">

                        <td>
                            {{ ((currentPage - 1) * pageSize) + index + 1 }}
                        </td>

                        <td>

                            <i class="fa-solid fa-car me-2"></i>

                            {{ model.model_Name }}

                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

        <!-- Pagination -->

        <nav v-if="totalPages > 1">

            <ul class="pagination justify-content-center">

                <li class="page-item"
                    :class="{disabled: currentPage === 1}">

                    <button class="page-link"
                        @@click="changePage(currentPage - 1)">

                        Previous

                    </button>

                </li>

                <li class="page-item"
                    v-for="page in totalPages"
                    :key="page"
                    :class="{active: page === currentPage}">

                    <button class="page-link"
                        @@click="changePage(page)">

                        {{ page }}

                    </button>

                </li>

                <li class="page-item"
                    :class="{disabled: currentPage === totalPages}">

                    <button class="page-link"
                        @@click="changePage(currentPage + 1)">

                        Next

                    </button>

                </li>

            </ul>

        </nav>

    </div>

    <div class="position-fixed top-0 end-0 p-3"
         style="z-index: 1055">

        <div id="errorToast"
             class="toast align-items-center text-white bg-danger border-0"
             role="alert">

            <div class="d-flex">

                <div class="toast-body">
                    {{ toastMessage }}
                </div>

                <button type="button"
                        class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast">
                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css"rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="~/js/carexplorer.js"></script>
}